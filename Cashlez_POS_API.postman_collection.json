            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"categoryId\": {{category_id}},\n  \"name\": \"Updated Category\",\n  \"image\": \"https://example.com/image.jpg\",\n  \"description\": \"Updated description\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
