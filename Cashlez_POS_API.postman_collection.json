              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/pos/category/single/add",
              "host": ["{{base_url}}"],
              "path": ["pos", "category", "single", "add"]
            },
            "description": "Create a new product category."
          },
          "response": [
            {
              "name": "200 Success",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"status\": \"SUCCESS\",\n  \"message\": \"Category added\",\n  \"data\": {\n    \"categoryId\": 5,\n    \"name\": \"Category Name\"\n  }\n}"
            }
          ]
        },
