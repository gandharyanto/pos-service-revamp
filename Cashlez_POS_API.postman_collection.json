          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "pos-token",     "value": "{{pos_token}}" },
              { "key": "pos-key",       "value": "{{pos_key}}" },
              { "key": "version-id",    "value": "{{version_id}}" },
              { "key": "device-id",     "value": "{{device_id}}" }
            ],
            "url": {
              "raw": "{{base_url}}/pos/category/detail/{{category_id}}",
              "host": ["{{base_url}}"],
              "path": ["pos", "category", "detail", "{{category_id}}"]
            },
            "description": "Get category detail by ID."
          },
          "response": []
        },
        {
