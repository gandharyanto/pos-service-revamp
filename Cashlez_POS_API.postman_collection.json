      ]
    },
    {
      "name": "Stock",
      "item": [
        {
          "name": "Update Stock",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization",  "value": "Bearer {{token}}" },
              { "key": "Content-Type",   "value": "application/json" },
              { "key": "pos-token",      "value": "{{pos_token}}" },
              { "key": "pos-key",        "value": "{{pos_key}}" },
              { "key": "version-id",     "value": "{{version_id}}" },
              { "key": "device-id",      "value": "{{device_id}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": {{product_id}},\n  \"qty\": 10,\n  \"updateType\": \"ADD\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/pos/stock/update",
              "host": ["{{base_url}}"],
              "path": ["pos", "stock", "update"]
            },
            "description": "Adjust product stock quantity. `updateType` values: `ADD`, `SUBTRACT`, `SET`."
          },
          "response": [
            {
              "name": "200 Success",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"status\": \"SUCCESS\",\n  \"message\": \"Stock updated\",\n  \"data\": {\n    \"trxId\": \"TRX-001\",\n    \"queueNumber\": \"Q-001\"\n  }\n}"
            }
          ]
        },
        {
          "name": "Get Stock Movement",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "pos-token",     "value": "{{pos_token}}" },
              { "key": "pos-key",       "value": "{{pos_key}}" },
              { "key": "version-id",    "value": "{{version_id}}" },
              { "key": "device-id",     "value": "{{device_id}}" }
            ],
            "url": {
              "raw": "{{base_url}}/pos/stock-movement/product/list?productId={{product_id}}&startDate=2024-01-01&endDate=2024-12-31",
