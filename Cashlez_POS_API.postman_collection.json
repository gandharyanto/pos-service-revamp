{
  "info": {
    "_postman_id": "cashlez-pos-api-collection",
    "name": "Cashlez POS API",
    "description": "API collection for Cashlez POS and POS-Core modules.\n\n## Setup\n1. Set the `base_url` variable to the appropriate environment URL.\n2. Run the **Auth > Login** request first — it will auto-set `token`, `pos_token`, and `pos_key` via the test script.\n3. Set `version_id` and `device_id` variables if needed.\n\n## Environments\n- Production (envOctopus): `https://octopus-decoupling.cashlez.com`\n- Shadow: `https://octopushadow.cashlez.com`\n- Staging (envSword): `https://sword-decoupling.cashlez.com`\n- SIT: `https://sword-sit-decoupling.cashlez.com`\n- Isat: `https://octopus-isat.cashlez.com`\n- LionFish (ASG): `https://lionfish-decoupling.cashlez.com`\n- Orca: `https://orca.cashlez.com`\n- Angelfish: `https://angelfish.cashlez.com`",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://octopus-decoupling.cashlez.com",
      "type": "string",
      "description": "Base URL. Change per environment."
    },
    {
      "key": "token",
      "value": "",
      "type": "string",
      "description": "JWT token from /pos/auth/login response. Auto-set by Login request."
    },
    {
      "key": "pos_token",
      "value": "",
      "type": "string",
      "description": "POS token from login. Auto-set by Login request."
    },
    {
      "key": "pos_key",
      "value": "",
      "type": "string",
      "description": "POS key from login. Auto-set by Login request."
    },
    {
      "key": "version_id",
      "value": "1",
      "type": "string",
      "description": "App version code (BuildConfig.VERSION_CODE)."
    },
    {
      "key": "device_id",
      "value": "DEVICE_SERIAL_NUMBER",
      "type": "string",
      "description": "Device serial number."
    },
    {
      "key": "username",
      "value": "your_username",
      "type": "string"
    },
    {
      "key": "product_id",
      "value": "1",
      "type": "string"
    },
    {
      "key": "category_id",
      "value": "1",
      "type": "string"
    },
    {
      "key": "transaction_id",
      "value": "1",
      "type": "string"
    },
    {
      "key": "merchant_trx_id",
      "value": "TRX-XXXX",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.data) {",
                  "    if (json.data.token)    pm.collectionVariables.set('token',     json.data.token);",
                  "    if (json.data.posToken) pm.collectionVariables.set('pos_token', json.data.posToken);",
                  "    if (json.data.posKey)   pm.collectionVariables.set('pos_key',   json.data.posKey);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"123456\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/pos/auth/login",
              "host": ["{{base_url}}"],
              "path": ["pos", "auth", "login"]
            },
            "description": "Authenticate and obtain POS JWT token. The test script auto-saves `token`, `pos_token`, and `pos_key` to collection variables."
          },
          "response": [
            {
              "name": "200 Success",
              "originalRequest": {
                "method": "POST",
                "header": [],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"username\": \"merchant_user\",\n  \"password\": \"123456\"\n}"
                },
                "url": { "raw": "{{base_url}}/pos/auth/login", "host": ["{{base_url}}"], "path": ["pos","auth","login"] }
              },
              "status": "OK",
              "code": 200,
              "body": "{\n  \"status\": \"SUCCESS\",\n  \"message\": \"Login success\",\n  \"data\": {\n    \"token\": \"eyJhbGciOiJIUzI1NiJ9...\",\n    \"posToken\": \"abc123\",\n    \"posKey\": \"xyz789\"\n  }\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "List Products",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "pos-token",     "value": "{{pos_token}}" },
              { "key": "pos-key",       "value": "{{pos_key}}" },
              { "key": "version-id",    "value": "{{version_id}}" },
              { "key": "device-id",     "value": "{{device_id}}" }
            ],
            "url": {
              "raw": "{{base_url}}/pos/product/list?size=20&page=0",
              "host": ["{{base_url}}"],
              "path": ["pos", "product", "list"],
              "query": [
                { "key": "size",       "value": "20",  "description": "Page size (required)" },
                { "key": "page",       "value": "0",   "description": "Page number (0-based)" },
                { "key": "categoryId", "value": "",    "description": "Filter by category ID (optional)", "disabled": true },
                { "key": "keyword",    "value": "",    "description": "Search keyword (optional)", "disabled": true },
                { "key": "startDate",  "value": "",    "description": "Filter start date (optional)", "disabled": true },
                { "key": "endDate",    "value": "",    "description": "Filter end date (optional)", "disabled": true },
                { "key": "upc",        "value": "",    "description": "Filter by UPC (optional)", "disabled": true },
                { "key": "sku",        "value": "",    "description": "Filter by SKU (optional)", "disabled": true },
                { "key": "sortBy",     "value": "createdDate", "description": "Sort field (optional)", "disabled": true },
                { "key": "sortDir",    "value": "ASC", "description": "Sort direction ASC/DESC (optional)", "disabled": true }
              ]
            },
            "description": "Get paginated list of products. Supports filtering by category, keyword, date range, UPC, and SKU."
          },
          "response": [
            {
              "name": "200 Success",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"status\": \"SUCCESS\",\n  \"message\": \"OK\",\n  \"meta\": { \"baseUrl\": \"https://...\" },\n  \"data\": [\n    {\n      \"id\": 1,\n      \"merchantId\": 100,\n      \"merchantName\": \"Merchant Name\",\n      \"name\": \"Product A\",\n      \"sku\": \"SKU-001\",\n      \"upc\": \"UPC-001\",\n      \"imageUrl\": \"https://.../image.jpg\",\n      \"imageThumbUrl\": \"https://.../thumb.jpg\",\n      \"description\": \"Product description\",\n      \"basePrice\": 10000.0,\n      \"finalPrice\": 11000.0,\n      \"isPriceIncludeTax\": false,\n      \"isTaxable\": true,\n      \"tax\": { \"taxId\": 1, \"taxName\": \"PPN\", \"taxPercentage\": 10.0, \"taxAmount\": 1000.0 },\n      \"qty\": 50,\n      \"createdDate\": \"2024-01-01T00:00:00\",\n      \"categories\": [],\n      \"productImages\": []\n    }\n  ],\n  \"page\": 0,\n  \"size\": 20,\n  \"totalElements\": 1,\n  \"totalPages\": 1\n}"
            }
          ]
        },
        {
          "name": "Get Product Detail",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "pos-token",     "value": "{{pos_token}}" },
              { "key": "pos-key",       "value": "{{pos_key}}" },
              { "key": "version-id",    "value": "{{version_id}}" },
              { "key": "device-id",     "value": "{{device_id}}" }
            ],
            "url": {
              "raw": "{{base_url}}/pos/product/detail/{{product_id}}",
              "host": ["{{base_url}}"],
              "path": ["pos", "product", "detail", "{{product_id}}"]
            },
            "description": "Get product detail by ID."
          },
          "response": []
        },
        {
          "name": "Add Product",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization",  "value": "Bearer {{token}}" },
              { "key": "Content-Type",   "value": "application/json" },
              { "key": "pos-token",      "value": "{{pos_token}}" },
              { "key": "pos-key",        "value": "{{pos_key}}" },
              { "key": "version-id",     "value": "{{version_id}}" },
              { "key": "device-id",      "value": "{{device_id}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Product Name\",\n  \"price\": 10000,\n  \"sku\": \"SKU-001\",\n  \"upc\": \"UPC-001\",\n  \"imageUrl\": \"https://example.com/image.jpg\",\n  \"imageThumbUrl\": \"https://example.com/thumb.jpg\",\n  \"description\": \"Product description\",\n  \"qty\": 100,\n  \"categoryIds\": [1, 2]\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/pos/product/add",
              "host": ["{{base_url}}"],
              "path": ["pos", "product", "add"]
            },
            "description": "Create a new product."
          },
          "response": [
            {
              "name": "200 Success",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"status\": \"SUCCESS\",\n  \"message\": \"Product added\",\n  \"data\": {\n    \"productId\": 123,\n    \"name\": \"Product Name\"\n  }\n}"
            }
          ]
        },
        {
          "name": "Update Product",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization",  "value": "Bearer {{token}}" },
              { "key": "Content-Type",   "value": "application/json" },
              { "key": "pos-token",      "value": "{{pos_token}}" },
              { "key": "pos-key",        "value": "{{pos_key}}" },
              { "key": "version-id",     "value": "{{version_id}}" },
              { "key": "device-id",      "value": "{{device_id}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": {{product_id}},\n  \"name\": \"Updated Product Name\",\n  \"price\": 12000,\n  \"sku\": \"SKU-001\",\n  \"upc\": \"UPC-001\",\n  \"imageUrl\": \"https://example.com/image.jpg\",\n  \"imageThumbUrl\": \"https://example.com/thumb.jpg\",\n  \"description\": \"Updated description\",\n  \"categoryIds\": [1]\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/pos/product/update",
              "host": ["{{base_url}}"],
              "path": ["pos", "product", "update"]
            },
            "description": "Update an existing product."
          },
          "response": []
        },
        {
          "name": "Delete Product",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "pos-token",     "value": "{{pos_token}}" },
              { "key": "pos-key",       "value": "{{pos_key}}" },
              { "key": "version-id",    "value": "{{version_id}}" },
              { "key": "device-id",     "value": "{{device_id}}" }
            ],
            "url": {
              "raw": "{{base_url}}/pos/product/delete/{{product_id}}",
              "host": ["{{base_url}}"],
              "path": ["pos", "product", "delete", "{{product_id}}"]
            },
            "description": "Delete a product by ID."
          },
          "response": [
            {
              "name": "200 Success",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"status\": \"SUCCESS\",\n  \"message\": \"Product deleted\",\n  \"data\": {\n    \"trxId\": \"TRX-001\",\n    \"queueNumber\": \"Q-001\"\n  }\n}"
            }
          ]
        },
        {
          "name": "Upload Product Image",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "pos-token",     "value": "{{pos_token}}" },
              { "key": "pos-key",       "value": "{{pos_key}}" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": "",
                  "description": "Image file to upload (jpg/png)"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/images/upload",
              "host": ["{{base_url}}"],
              "path": ["images", "upload"]
            },
            "description": "Upload product/category image. Returns full URL and thumbnail URL. Upload timeout is 2 minutes."
          },
          "response": [
            {
              "name": "200 Success",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"status\": \"SUCCESS\",\n  \"message\": \"Upload success\",\n  \"data\": {\n    \"urlFull\": \"https://cdn.cashlez.com/images/product_full.jpg\",\n    \"urlThumb\": \"https://cdn.cashlez.com/images/product_thumb.jpg\"\n  }\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Categories",
      "item": [
        {
          "name": "List Categories",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "pos-token",     "value": "{{pos_token}}" },
              { "key": "pos-key",       "value": "{{pos_key}}" },
              { "key": "version-id",    "value": "{{version_id}}" },
              { "key": "device-id",     "value": "{{device_id}}" }
            ],
            "url": {
              "raw": "{{base_url}}/pos/category/list?size=100",
              "host": ["{{base_url}}"],
