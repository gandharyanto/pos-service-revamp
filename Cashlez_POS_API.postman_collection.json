              ]
            },
            "description": "Get stock movement history for a specific product within a date range."
          },
          "response": [
            {
              "name": "200 Success",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"status\": \"SUCCESS\",\n  \"message\": \"OK\",\n  \"data\": [\n    {\n      \"productId\": 1,\n      \"qty\": 10,\n      \"movementType\": \"ADD\",\n      \"movementReason\": \"Restock\",\n      \"localDateTime\": \"2024-06-01T10:00:00\"\n    }\n  ],\n  \"page\": 0,\n  \"size\": 20,\n  \"totalElements\": 1,\n  \"totalPages\": 1\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Payment Settings",
      "item": [
        {
          "name": "Get Payment Setting",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "pos-token",     "value": "{{pos_token}}" },
              { "key": "pos-key",       "value": "{{pos_key}}" },
              { "key": "version-id",    "value": "{{version_id}}" },
              { "key": "device-id",     "value": "{{device_id}}" }
            ],
            "url": {
              "raw": "{{base_url}}/pos/payment-setting",
              "host": ["{{base_url}}"],
              "path": ["pos", "payment-setting"]
            },
            "description": "Get merchant payment settings (tax, service charge, rounding)."
          },
          "response": [
            {
              "name": "200 Success",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"status\": \"SUCCESS\",\n  \"message\": \"OK\",\n  \"data\": {\n    \"paymentSettingId\": 1,\n    \"isPriceIncludeTax\": false,\n    \"isRounding\": true,\n    \"roundingTarget\": 100,\n    \"roundingType\": \"ROUND_HALF_UP\",\n    \"isServiceCharge\": false,\n    \"serviceChargePercentage\": 0.0,\n    \"serviceChargeAmount\": 0.0,\n    \"isTax\": true,\n    \"taxPercentage\": 11.0,\n    \"taxName\": \"PPN\"\n  }\n}"
            }
          ]
        },
        {
          "name": "Create Payment Setting",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization",  "value": "Bearer {{token}}" },
              { "key": "Content-Type",   "value": "application/json" },
              { "key": "pos-token",      "value": "{{pos_token}}" },
              { "key": "pos-key",        "value": "{{pos_key}}" },
              { "key": "version-id",     "value": "{{version_id}}" },
              { "key": "device-id",      "value": "{{device_id}}" }
            ],
